# knoten configuration. Copy to .env and fill in.
#
# Discovery order (first value wins):
#   1. explicit --env-file (tests / advanced)
#   2. ~/.config/knoten/.env  (user-level pointer, used by the installed CLI)
#   3. $KNOTEN_HOME/.env      (layered automatically once KNOTEN_HOME is known)
#   4. <repo>/.env            (dev workflow — this file)
#   5. ~/.knoten/.env         (fallback home)
#
# Process env vars always override any file.

# Mode selection.
#   auto   — local if KNOTEN_API_URL is empty, else remote (default).
#   local  — operate on an on-disk vault only. No network, no token required.
#   remote — mirror a notes.vcoeur.com instance (requires URL + token below).
# KNOTEN_MODE=auto

# notes.vcoeur.com API base URL. Leave empty (the default) for local mode.
# Example: KNOTEN_API_URL=https://notes.vcoeur.com
KNOTEN_API_URL=

# API token (Bearer). Only required in remote mode. Must have the `api` scope.
# Obtain from the notes.vcoeur.com setup screen or POST /api/tokens.
# Shown only once at creation time — store it here or in a password manager.
# KNOTEN_API_TOKEN=nt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the root path for vault + state.
# Defaults to the directory containing pyproject.toml (dev) or ~/.knoten
# (installed CLI with no ~/.config/knoten/.env pointer).
# KNOTEN_HOME=~/src/vcoeur/knoten

# Optional: override the vault directory name (relative to KNOTEN_HOME).
# The default is `kasten` — the dev-only gitignored mirror lives there.
# KNOTEN_VAULT_DIR=kasten

# Optional: override the state directory name (relative to KNOTEN_HOME).
# KNOTEN_STATE_DIR=.knoten-state

# Optional: HTTP request timeout in seconds.
# KNOTEN_HTTP_TIMEOUT=30
