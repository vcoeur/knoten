# KastenManager configuration. Copy to .env and fill in.

# notes.vcoeur.com API base URL
KASTEN_API_URL=https://notes.vcoeur.com

# API token (Bearer). Must have the `api` scope.
# Obtain from the notes.vcoeur.com setup screen or POST /api/tokens.
# Shown only once at creation time — store it here or in a password manager.
KASTEN_API_TOKEN=nt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the root path for vault + state.
# Defaults to the directory containing pyproject.toml.
# KASTEN_HOME=/home/alice/src/vcoeur/KastenManager

# Optional: override the vault directory name (relative to KASTEN_HOME).
# KASTEN_VAULT_DIR=kasten

# Optional: override the state directory name (relative to KASTEN_HOME).
# KASTEN_STATE_DIR=.kasten-state

# Optional: HTTP request timeout in seconds.
# KASTEN_HTTP_TIMEOUT=30
