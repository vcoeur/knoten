# KastenManager configuration. Copy to .env and fill in.
#
# Discovery order (first value wins):
#   1. explicit --env-file (tests / advanced)
#   2. ~/.config/kasten/.env  (user-level pointer, used by the installed CLI)
#   3. $KASTEN_HOME/.env     (layered automatically once KASTEN_HOME is known)
#   4. <repo>/.env           (dev workflow — this file)
#   5. ~/.kasten/.env        (fallback home)
#
# Process env vars always override any file.

# Mode selection.
#   auto   — local if KASTEN_API_URL is empty, else remote (default).
#   local  — operate on an on-disk vault only. No network, no token required.
#   remote — mirror a notes.vcoeur.com instance (requires URL + token below).
# KASTEN_MODE=auto

# notes.vcoeur.com API base URL. Leave empty (the default) for local mode.
# Example: KASTEN_API_URL=https://notes.vcoeur.com
KASTEN_API_URL=

# API token (Bearer). Only required in remote mode. Must have the `api` scope.
# Obtain from the notes.vcoeur.com setup screen or POST /api/tokens.
# Shown only once at creation time — store it here or in a password manager.
# KASTEN_API_TOKEN=nt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the root path for vault + state.
# Defaults to the directory containing pyproject.toml (dev) or ~/.kasten
# (installed CLI with no ~/.config/kasten/.env pointer).
# KASTEN_HOME=~/src/KastenManager

# Optional: override the vault directory name (relative to KASTEN_HOME).
# KASTEN_VAULT_DIR=kasten

# Optional: override the state directory name (relative to KASTEN_HOME).
# KASTEN_STATE_DIR=.kasten-state

# Optional: HTTP request timeout in seconds.
# KASTEN_HTTP_TIMEOUT=30
